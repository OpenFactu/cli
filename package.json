{
  "name": "@openfactu/cli",
  "version": "0.0.7",
  "description": "CLI para gestionar OpenFactu: migraciones, tenants, plugins y setup",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "openfactu": "./dist/bin/openfactu.js"
  },
  "files": [
    "dist",
