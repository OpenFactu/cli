    "drizzle-orm": "^0.45.2",
    "inquirer": "^8.2.6",
    "inquirer-autocomplete-prompt": "^2.0.1",
    "ora": "^5.4.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.0",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^4.1.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.6"
  }
}
